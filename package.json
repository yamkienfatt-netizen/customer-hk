{
  "name": "easthotels",
  "description": "Application utilizing Sitecore JavaScript Services and Next.js",
  "version": "22.12.0",
  "private": true,
  "config": {
    "appName": "easthotels",
    "rootPlaceholders": [
      "jss-main"
    ],
    "sitecoreConfigPath": "/App_Config/Include/zzz",
    "graphQLEndpointPath": "/sitecore/api/graph/edge",
    "graphQLEndpointPath2": "/api/graphql/v1",
    "language": "en",
    "templates": [
      "nextjs",
      "nextjs-sxa",
      "nextjs-personalize",
      "nextjs-multisite"
    ]
  },
  "engines": {
    "node": ">=12",
    "npm": ">=6"
  },
  "author": {
    "name": "Sitecore Corporation",
    "url": "https://jss.sitecore.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sitecore/jss.git"
  },
  "bugs": {
    "url": "https://github.com/sitecore/jss/issues"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@alicloud/captcha20230305": "^1.1.3",
    "@alicloud/openapi-client": "^0.4.15",
    "@amap/amap-jsapi-loader": "^1.0.1",
    "@hookform/resolvers": "^3.3.4",
    "@next/third-parties": "^16.1.1",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@reduxjs/toolkit": "^2.2.1",
    "@sitecore-cloudsdk/core": "^0.5.2",
    "@sitecore-cloudsdk/events": "^0.5.2",
    "@sitecore-cloudsdk/personalize": "^0.5.2",
    "@sitecore-feaas/clientside": "^0.6.2",
    "@sitecore-jss/sitecore-jss-nextjs": "~22.12.0",
    "@sitecore/components": "~2.1.0",
    "@tanstack/react-query": "^5.100.6",
    "@uidotdev/usehooks": "^2.4.1",
    "@vercel/functions": "^3.6.2",
    "bootstrap": "^5.1.3",
    "cache-manager": "^5.5.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cookie": "^1.1.1",
    "date-fns": "^3.1.0",
    "emailjs": "^4.0.3",
    "font-awesome": "^4.7.0",
    "framer-motion": "^12.38.0",
    "html-react-parser": "^5.1.1",
    "ip-location-api": "^4.0.4",
    "js-cookie": "^3.0.5",
    "jwt-encode": "^1.0.1",
    "lucide-react": "^1.8.0",
    "memory-cache": "^0.2.0",
    "next": "^16.1.1",
    "next-auth": "^4.24.7",
    "next-localization": "^0.12.0",
    "next-redux-wrapper": "^8.1.0",
    "papaparse": "^5.4.1",
    "password-validator": "^5.3.0",
    "react": "^19.1.0",
    "react-cool-dimensions": "^3.0.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.49.3",
    "react-redux": "^9.1.0",
    "react-scroll": "^1.9.0",
    "sass": "^1.52.3",
    "sharp": "^0.34.3",
    "swiper": "^11.0.5",
    "tailwind-merge": "^2.2.0",
    "tailwind-scrollbar-hide": "^4.0.0",
    "tailwindcss-animate": "^1.0.7",
    "util": "^0.12.5",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@sitecore-jss/sitecore-jss-cli": "~22.12.0",
    "@sitecore-jss/sitecore-jss-dev-tools": "~22.12.0",
    "@types/js-cookie": "^3.0.6",
    "@types/jwt-encode": "^1.0.3",
    "@types/node": "^24.10.4",
    "@types/react": "^19.1.7",
    "@types/react-dom": "^19.1.7",
    "@types/react-scroll": "^1.8.10",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "autoprefixer": "^10.4.16",
    "chalk": "~4.1.2",
    "chokidar": "~4.0.3",
    "constant-case": "^3.0.4",
    "cross-env": "~10.0.0",
    "dotenv-flow": "^4.1.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.2.35",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-yaml": "^0.5.0",
    "npm-run-all": "~4.1.5",
    "postcss": "^8.4.31",
    "prettier": "^3.2.4",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.3.5",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.1.2",
    "typescript": "~5.4.0",
    "yaml-loader": "^0.8.0"
  },
  "scripts": {
    "updatedb": "cross-env NODE_ENV=production node --require dotenv-flow/config node_modules/ip-location-api/script/updatedb.mjs",
    "bootstrap": "ts-node --require dotenv-flow/config --project tsconfig.scripts.json scripts/bootstrap.ts",
    "build": "cross-env NODE_ENV=production npm-run-all --serial bootstrap next:build",
    "install-pre-push-hook": "ts-node --project tsconfig.scripts.json ./scripts/install-pre-push-hook.ts",
    "jss": "jss",
    "lint": "eslint ./src/**/*.tsx ./src/**/*.ts ./scripts/**/*.ts",
    "format": "prettier --write \"**/*.{ts,tsx,md,mdx,css,scss}\"",
    "next:build": "next build --webpack",
    "next:dev": "cross-env NODE_OPTIONS='--inspect' next dev -p 3000 --webpack",
    "next:start": "next start",
    "next:prod": "next start -p 3000",
    "scaffold": "ts-node --project tsconfig.scripts.json scripts/scaffold-component.ts",
    "start": "npm-run-all --serial start:production",
    "start:connected": "npm-run-all --serial bootstrap --parallel next:dev start:watch-components",
    "start:production": "NODE_OPTIONS=--max-old-space-size=4096 npm-run-all --serial bootstrap next:build next:start",
    "start:prod": "cross-env-shell NODE_OPTIONS=--max-old-space-size=4096 npm-run-all --serial bootstrap next:build next:prod",
    "start:watch-components": "ts-node --project tsconfig.scripts.json scripts/generate-component-builder/index.ts --watch"
  }
}
